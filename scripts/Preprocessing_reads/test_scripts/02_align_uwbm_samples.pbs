#!/bin/bash
#PBS -V
#PBS -N align_mem2_only
#PBS -l nodes=1:ppn=20,mem=64gb,walltime=24:00:00
#PBS -q batch
#PBS -j oe
#PBS -o /usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/out/align_mem2_only_uwbm_samples.log

set -euo pipefail
cd "$PBS_O_WORKDIR"
source ~/miniconda3/etc/profile.d/conda.sh; 
conda activate genomics

REF="/usr/scratch2/userdata2/mtofflemire/references/ncbi_dataset/data/GCF_014839835.1/GCF_014839835.1_bDryPub1.pri_genomic.fna"
INPUT_DIR="/usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/data/fastq"
OUTDIR="/usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/data/alignments2"
THREADS=20
mkdir -p "$OUTDIR"

for R1 in \
  "$INPUT_DIR/25002Bns_Palb-UWBM51058_S62_L007_R1_001.fastq.gz" \
  "$INPUT_DIR/25002Bns_Palb-UWBM57122_S63_L007_R1_001.fastq.gz"
do
  [ -e "$R1" ] || { echo "Missing $R1"; continue; }
  R2="${R1/_R1/_R2}"; [ -f "$R2" ] || { echo "Missing mate for $R1"; continue; }
  base="$(basename "$R1")"; BASENAME="${base%%_R1*}"
  SAMPLE="$(echo "$BASENAME" | awk -F'_' '{print $2}')"
  LANE="$(echo "$BASENAME"   | awk -F'_' '{print $3"_"$4}')"
  RGID="${SAMPLE}_${LANE}"; RGSM="$SAMPLE"; RGPU="$LANE"; RGLB="lib1"; RGPL="ILLUMINA"

  bwa-mem2 mem -t $THREADS -R "@RG\tID:${RGID}\tSM:${RGSM}\tLB:${RGLB}\tPL:${RGPL}\tPU:${RGPU}" "$REF" "$R1" "$R2" \
    | samtools sort -@ $((THREADS/2)) -o "${OUTDIR}/${BASENAME}.sorted.bam" -
  samtools index "${OUTDIR}/${BASENAME}.sorted.bam"
  samtools flagstat "${OUTDIR}/${BASENAME}.sorted.bam" > "${OUTDIR}/${BASENAME}.flagstat.txt"
done

