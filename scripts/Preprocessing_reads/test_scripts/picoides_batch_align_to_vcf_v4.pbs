#!/bin/bash
#PBS -V
#PBS -N picoides_array
#PBS -l nodes=1:ppn=16,mem=128gb,walltime=48:00:00
#PBS -q batch
#PBS -j oe
#PBS -o /usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/out/array_$PBS_ARRAYID.log
# (No -t line here; pass -t on qsub CLI)

set -euo pipefail
cd "$PBS_O_WORKDIR"

# ===== env =====
source ~/miniconda3/etc/profile.d/conda.sh
conda activate genomics
export _JAVA_OPTIONS="-Xms2g -Xmx96g -XX:ParallelGCThreads=4"
# Ensure GATK uses native AVX PairHMM for speed
export JAVA_TOOL_OPTIONS="${JAVA_TOOL_OPTIONS:-} -Djava.library.path=$CONDA_PREFIX/lib"

# Node-local tmp
TMPDIR="${PBS_JOBTMP:-/tmp}/${USER}_${PBS_JOBID:-$$}"
mkdir -p "$TMPDIR"
trap 'rm -rf "$TMPDIR"' EXIT
export TMPDIR

# Prefer bwa-mem2 if available
BWA=$(command -v bwa-mem2 || command -v bwa)

# ===== inputs/outputs =====
REF="/usr/scratch2/userdata2/mtofflemire/references/ncbi_dataset/data/GCF_014839835.1/GCF_014839835.1_bDryPub1.pri_genomic.fna"
FASTQ_MANIFEST="/usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/data/r1_list.txt"
ALIGN_DIR="/usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/data/alignments"
OUT_LOG_DIR="/usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/out"
mkdir -p "$ALIGN_DIR" "$OUT_LOG_DIR"

# ===== reference indices =====
if [[ $(basename "$BWA") == "bwa-mem2" ]]; then
  [ -f "${REF}.0123" ] || bwa-mem2 index "$REF"
else
  [ -f "${REF}.bwt" ]  || bwa index "$REF"
fi
[ -f "${REF}.fai" ]     || samtools faidx "$REF"
[ -f "${REF%.*}.dict" ] || gatk CreateSequenceDictionary -R "$REF" -O "${REF%.*}.dict"

# ===== select sample from manifest =====
if [[ ! -s "$FASTQ_MANIFEST" ]]; then
  echo "Manifest not found or empty: $FASTQ_MANIFEST" >&2; exit 1
fi
R1=$(sed -n "${PBS_ARRAYID}p" "$FASTQ_MANIFEST") || true
if [[ -z "${R1:-}" || ! -f "$R1" ]]; then
  echo "Bad or missing R1 on line $PBS_ARRAYID in $FASTQ_MANIFEST" >&2; exit 1
fi
R2="${R1/_R1_001.fastq.gz/_R2_001.fastq.gz}"
if [[ ! -f "$R2" ]]; then
  echo "Mate R2 missing for $(basename "$R1") (expected $(basename "$R2"))" >&2; exit 1
fi

# ===== names & read group =====
base=$(basename "$R1")
BASENAME="${base%%_R1_001.fastq.gz}"
SAMPLE="$(echo "$BASENAME" | awk -F'_' '{print $2}')"
L1="$(echo "$BASENAME"    | awk -F'_' '{print $3}')"
L2="$(echo "$BASENAME"    | awk -F'_' '{print $4}')"
LANE="${L1}_${L2}"
RGID="${SAMPLE}_${LANE}"
RGPU="$LANE"
RGSM="$SAMPLE"
RG="@RG\tID:${RGID}\tLB:lib1\tPL:ILLUMINA\tPU:${RGPU}\tSM:${RGSM}"

BAM_SORTED="${ALIGN_DIR}/${BASENAME}.sorted.bam"
BAM_DEDUP="${ALIGN_DIR}/${BASENAME}.dedup.bam"
METRICS="${ALIGN_DIR}/${BASENAME}.dup_metrics.txt"
GVCF="${ALIGN_DIR}/${BASENAME}.g.vcf.gz"

echo "[$(date)] Start: $BASENAME (array $PBS_ARRAYID) on $(hostname)"
echo "TMPDIR: $TMPDIR | BWA: $(basename "$BWA")"

# ===== align + sort (add RG inline; node-local temp) =====
if [[ $(basename "$BWA") == "bwa-mem2" ]]; then
  bwa-mem2 mem -t 16 -K 100000000 -R "$RG" "$REF" "$R1" "$R2" \
    | samtools sort -@ 8 -l 1 -m 3G -T "$TMPDIR/${BASENAME}.tmp" -o "$BAM_SORTED" -
else
  bwa mem -t 16 -K 100000000 -R "$RG" "$REF" "$R1" "$R2" \
    | samtools sort -@ 8 -l 1 -m 3G -T "$TMPDIR/${BASENAME}.tmp" -o "$BAM_SORTED" -
fi
samtools index -@ 4 "$BAM_SORTED"
samtools flagstat -@ 4 "$BAM_SORTED" > "${ALIGN_DIR}/${BASENAME}.flagstat.txt"
samtools idxstats "$BAM_SORTED" > "${ALIGN_DIR}/${BASENAME}.idxstats.txt"

# ===== duplicates =====
echo "[$(date)] MarkDuplicates: $BASENAME"
picard MarkDuplicates \
  I="$BAM_SORTED" O="$BAM_DEDUP" M="$METRICS" \
  CREATE_INDEX=true VALIDATION_STRINGENCY=SILENT

# ===== gVCF calling =====
echo "[$(date)] HaplotypeCaller: $BASENAME"
gatk --java-options "-Djava.library.path=$CONDA_PREFIX/lib" HaplotypeCaller \
  -R "$REF" -I "$BAM_DEDUP" -O "$GVCF" -ERC GVCF \
  --native-pair-hmm-threads 8

echo "[$(date)] Done: $BASENAME"

