#!/bin/bash
#PBS -V
#PBS -N toxo_batch_align_to_vcf
#PBS -l nodes=1:ppn=16,mem=128gb,walltime=48:00:00
#PBS -q batch
#PBS -j oe
#PBS -o /usr/scratch2/userdata2/mtofflemire/projects/toxostoma_wgs/out/batch_align_to_vcfv2.log
#PBS -M mtofflemire@sdsu.edu

set -euo pipefail
cd "$PBS_O_WORKDIR"

# ---- activate env ----
source ~/miniconda3/etc/profile.d/conda.sh
conda activate genomics
export _JAVA_OPTIONS="-Xms2g -Xmx96g -XX:ParallelGCThreads=4"

# ===== paths (updated) =====
REF="/usr/scratch2/userdata2/mtofflemire/projects/toxostoma_wgs/data/references/GCA_013397375.1_ASM1339737v1_genomic.fna"
FASTQ_DIR="/usr/scratch2/userdata2/mtofflemire/projects/toxostoma_wgs/data/fastq-mesx-test"
OUTDIR="/usr/scratch2/userdata2/mtofflemire/projects/toxostoma_wgs/data/alignments"
THREADS=16
# ==========================

# outputs still go to shared scratch; temps go to node-local
mkdir -p "$OUTDIR" "/usr/scratch2/userdata2/mtofflemire/projects/toxostoma_wgs/out"

TMPDIR_JOB="${PBS_JOBTMP:-/tmp}/${USER}_${PBS_JOBID:-$$}"
mkdir -p "$TMPDIR_JOB"
export TMPDIR="$TMPDIR_JOB"
trap 'rm -rf "$TMPDIR_JOB"' EXIT

# Index reference once
[ -f "${REF}.bwt" ] || bwa index "$REF"
[ -f "${REF}.fai" ] || samtools faidx "$REF"
DICT="${REF%.*}.dict"; [ -f "$DICT" ] || gatk CreateSequenceDictionary -R "$REF" -O "$DICT"

for R1 in "$FASTQ_DIR"/*_R1_*.fastq.gz; do
  [ -e "$R1" ] || { echo "No R1 files found in $FASTQ_DIR"; exit 1; }
  R2="${R1/_R1_/_R2_}"
  if [[ ! -f "$R2" ]]; then
    echo "Missing mate for $R1 (expected $R2) — skipping"
    continue
  fi

  # Derive a base name like: 25002Bns_Tred-CAS90579_S13_L007
  base="$(basename "$R1")"
  BASENAME="${base%%_R1_*}"

  # Read group fields (adjust if your naming differs)
  SAMPLE="$(echo "$BASENAME" | awk -F'_' '{print $2}')"       # e.g., Tred-CAS90579
  LANE="$(echo "$BASENAME"   | awk -F'_' '{print $3"_"$4}')"  # e.g., S13_L007
  RGID="${SAMPLE}_${LANE}"
  RGPU="$LANE"
  RGSM="$SAMPLE"

  echo ">>> Processing $BASENAME"
  BAM_SORTED="${OUTDIR}/${BASENAME}.sorted.bam"
  BAM_RG="${OUTDIR}/${BASENAME}.sorted_rg.bam"
  BAM_DEDUP="${OUTDIR}/${BASENAME}.dedup.bam"
  METRICS="${OUTDIR}/${BASENAME}.dup_metrics.txt"
  GVCF="${OUTDIR}/${BASENAME}.g.vcf.gz"

  # Align & sort (use node-local TMPDIR for sort temps)
  bwa mem -t "$THREADS" "$REF" "$R1" "$R2" \
    | samtools sort -@ $((THREADS/2)) -T "$TMPDIR/${BASENAME}.tmp" -o "$BAM_SORTED" -
  samtools index "$BAM_SORTED"

  # Quick mapping summary
  samtools flagstat "$BAM_SORTED" > "${OUTDIR}/${BASENAME}.flagstat.txt"
  samtools idxstats "$BAM_SORTED" > "${OUTDIR}/${BASENAME}.idxstats.txt"

  # Add read groups
  picard AddOrReplaceReadGroups \
    I="$BAM_SORTED" \
    O="$BAM_RG" \
    RGID="$RGID" RGLB="lib1" RGPL="ILLUMINA" RGPU="$RGPU" RGSM="$RGSM" \
    CREATE_INDEX=true VALIDATION_STRINGENCY=SILENT

  # Mark duplicates
  picard MarkDuplicates \
    I="$BAM_RG" \
    O="$BAM_DEDUP" \
    M="$METRICS" \
    CREATE_INDEX=true VALIDATION_STRINGENCY=SILENT

  # Call variants (GVCF)
  gatk HaplotypeCaller \
    -R "$REF" \
    -I "$BAM_DEDUP" \
    -O "$GVCF" \
    -ERC GVCF

  echo "✔ $BASENAME -> $GVCF"
done

