# 12_run_admixture_simple.pbs
#!/bin/bash
#PBS -V
#PBS -N admixture_picoides
#PBS -l nodes=1:ppn=20,mem=128gb,walltime=04:00:00
#PBS -q batch
#PBS -o /usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/out/admixture.log
#PBS -j oe

set -euo pipefail
cd "$PBS_O_WORKDIR"

source ~/miniconda3/etc/profile.d/conda.sh
conda activate admixture_env

# --- paths ---
OUT2=/usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/out2
PREFIX=$OUT2/picoides.like_paper.thin1kb   # <- matches the BED we just made

# (bim already numeric-coded by previous step; leaving this here harmlessly)
BIM=${PREFIX}.bim
awk 'BEGIN{OFS="\t"}{$1=0; print}' "$BIM" > ${BIM}.tmp && mv ${BIM}.tmp "$BIM"

# run admixture for K = 1..5 (same as your original)
for K in {1..5}; do
  admixture --cv=10 -j20 ${PREFIX}.bed $K | tee ${PREFIX}.K${K}.log
done


