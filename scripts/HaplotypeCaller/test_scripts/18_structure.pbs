#!/bin/bash
#PBS -V
#PBS -N faststr_picoides
#PBS -l nodes=1:ppn=8,mem=24gb,walltime=02:00:00
#PBS -q batch
#PBS -o /usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/out/faststructure.log
#PBS -j oe

set -euo pipefail
cd "$PBS_O_WORKDIR"

source ~/miniconda3/etc/profile.d/conda.sh
conda activate faststr

OUT2=/usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/out2
cd "$OUT2"

for K in {1..5}; do
  structure.py -K "$K" --input=picoides --format=bed --prior=simple --seed 123 \
               --output=fs
done

chooseK.py --input=fs > fs.chooseK.txt
echo "Done. See $OUT2/fs.chooseK.txt and fs.*.meanQ"

