#!/bin/bash
#PBS -V
#PBS -N gdb_array
#PBS -l nodes=1:ppn=8,mem=64gb,walltime=500:00:00
#PBS -q batch
#PBS -o /usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/out/gdb_array.$PBS_ARRAYID.log
#PBS -j oe
#PBS -t 0-47%12
set -euo pipefail
ulimit -n 4096 || true
cd "$PBS_O_WORKDIR"

# env
source ~/miniconda3/etc/profile.d/conda.sh
conda activate genomics

# paths
PRJ=/usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping
OUT=$PRJ/SNP_calling/joint_gatk4_gdb
REF=/usr/scratch2/userdata2/mtofflemire/references/ncbi_dataset/data/GCF_014839835.1/GCF_014839835.1_bDryPub1.pri_genomic.fna
SHARDS_DIR=$OUT/shards
SAMPLE_MAP=$OUT/sample_map.txt

# make sure ref index + dict are present (needed for *.interval_list)
[ -s "${REF}.fai" ] || samtools faidx "$REF"
DICT="${REF%.*}.dict"
[ -s "$DICT" ] || gatk CreateSequenceDictionary -R "$REF" -O "$DICT"

# pick this shard's interval_list
ID=$(printf "%03d" "${PBS_ARRAYID}")
LIST=$(ls -1 "$SHARDS_DIR"/*.interval_list | sort -V | sed -n "$((PBS_ARRAYID+1))p")
[ -s "$LIST" ] || { echo "No interval_list for index $PBS_ARRAYID in $SHARDS_DIR"; exit 1; }
[ -s "$SAMPLE_MAP" ] || { echo "Missing $SAMPLE_MAP"; exit 1; }

# outputs
DB=$OUT/genomicsdb.$ID
VCF=$OUT/cohort.raw.$ID.vcf.gz

# import + genotype (use some of your 64 GB for heap)
gatk --java-options "-Xmx48g -Xms48g -XX:+UseParallelGC" GenomicsDBImport \
  --sample-name-map "$SAMPLE_MAP" \
  --genomicsdb-workspace-path "$DB" \
  -L "$LIST"

gatk --java-options "-Xmx48g -Xms48g -XX:+UseParallelGC" GenotypeGVCFs \
  -R "$REF" -V "gendb://$DB" -O "$VCF"

