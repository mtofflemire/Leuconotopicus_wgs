#!/bin/bash
#PBS -V
#PBS -N array_genomicsdb_genotype
#PBS -l nodes=ram15tb:ppn=48
#PBS -q batch
#PBS -j oe
#PBS -l walltime=500:00:00
#PBS -o /usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/out/array_genomicsdb_gvcf.log
#PBS -t 0-47%5   # Adjust % concurrency as appropriate

set -euo pipefail
ulimit -n 4096 || true

cd "$PBS_O_WORKDIR"

# ======== Load environment ========
source ~/miniconda3/etc/profile.d/conda.sh
conda activate genomics

# ======== Paths & parameters ========
REF=/usr/scratch2/userdata2/mtofflemire/references/ncbi_dataset/data/GCF_014839835.1/GCF_014839835.1_bDryPub1.pri_genomic.fna
GVCF_DIR=/usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/gvcf
SHARDS_DIR=/usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/SNP_calling/joint_gatk4_gdb/shards2
OUT_DIR=/usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/SNP_calling/joint_gatk4_gdb/genomicsdb_gvcf_1
mkdir -p "$OUT_DIR"

SAMPLE_MAP="$OUT_DIR/sample_map.txt"

# ======== Prepare sample map (one-time) ========
if [ ! -s "$SAMPLE_MAP" ]; then
    ls -1 "$GVCF_DIR"/*.g.vcf.gz | \
    awk -F/ '{f=$NF; sub(/.g.vcf.gz$/,"",f); print f "\t"$0}' \
    > "$SAMPLE_MAP"
fi

# ======== This shard's interval file ========
IDX=$(printf "%04d" "$PBS_ARRAYID")
INTERVAL_FILE="$SHARDS_DIR/${IDX}-scattered.interval_list"

[ -s "$INTERVAL_FILE" ] || { echo "Missing interval file: $INTERVAL_FILE"; exit 1; }
[ -s "$SAMPLE_MAP" ] || { echo "Missing sample map: $SAMPLE_MAP"; exit 1; }

# ======== Local scratch for fast I/O ========
TMP="${PBSJOBTMP:-/tmp}/gatk${PBS_JOBID:-$$}"
mkdir -p "$TMP"

DB="$TMP/genomicsdb.${IDX}"
VCF="$OUT_DIR/cohort.raw.${IDX}.vcf.gz"

# ======== Step 1: Create GenomicsDB workspace ========
gatk --java-options "-Xmx36g -Xms36g -XX:+UseParallelGC" GenomicsDBImport \
    --sample-name-map "$SAMPLE_MAP" \
    --genomicsdb-workspace-path "$DB" \
    --overwrite-existing-genomicsdb-workspace \
    --tmp-dir "$TMP" \
    --reader-threads 8 \
    -L "$INTERVAL_FILE"

# ======== Step 2: Genotype GVCFs ========
gatk --java-options "-Xmx36g -Xms36g -XX:+UseParallelGC" GenotypeGVCFs \
    -R "$REF" \
    -V "gendb://$DB" \
    -O "$VCF"

# ======== Step 3: Clean up ========
rm -rf "$DB"
touch "$VCF.done"
echo "Completed shard $PBS_ARRAYID -> $VCF"
date
