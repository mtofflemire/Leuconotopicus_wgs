#!/bin/bash
# ===== PBS directives =====
#PBS -V
#PBS -N picoides_batch_trim_align_to_gvcf
#PBS -l nodes=1:ppn=16,mem=128gb,walltime=48:00:00
#PBS -q batch
#PBS -j oe
#PBS -o /usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/out/batch_trim_align_to_gvcf.log
#PBS -M mtofflemire@sdsu.edu
#PBS -m abe   # email on abort/begin/end (optional)

set -euo pipefail
cd "$PBS_O_WORKDIR"

# ===== activate environment =====
source ~/miniconda3/etc/profile.d/conda.sh
conda activate genomics

# Java & temp hygiene
export _JAVA_OPTIONS="-Xms4g -Xmx96g -XX:ParallelGCThreads=4"
TMPDIR="/usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/tmp"
mkdir -p "$TMPDIR"
export TMPDIR

# ===== paths =====
REF="/usr/scratch2/userdata2/mtofflemire/references/ncbi_dataset/data/GCF_014839835.1/GCF_014839835.1_bDryPub1.pri_genomic.fna"
FASTQ_DIR="/usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/data/fastq"
TRIMDIR="/usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/data/trimmed"
OUTDIR="/usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/data/alignments2"   # <--- new directory
LOGDIR="/usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/out"
THREADS=16

mkdir -p "$TRIMDIR" "$OUTDIR" "$LOGDIR" "$TMPDIR"

# ===== reference indexes (idempotent) =====
if [ ! -f "${REF}.0123" ]; then
  echo "[INFO] Building bwa-mem2 index for $REF"
  bwa-mem2 index "$REF"
fi
[ -f "${REF}.fai" ] || samtools faidx "$REF"
DICT="${REF%.*}.dict"; [ -f "$DICT" ] || gatk CreateSequenceDictionary -R "$REF" -O "$DICT"

# ===== per-sample processing =====
for R1 in "$FASTQ_DIR"/*_R1_*.fastq.gz; do
  [ -e "$R1" ] || { echo "No R1 files found in $FASTQ_DIR"; exit 1; }
  R2="${R1/_R1_/_R2_}"
  if [[ ! -f "$R2" ]]; then
    echo "[WARN] Missing mate for $R1 (expected $R2) — skipping"
    continue
  fi

  base=$(basename "$R1")
  BASENAME="${base%%_R1_*}"
  SAMPLE="$(echo "$BASENAME" | awk -F'_' '{print $2}')"
  LANE="$(echo "$BASENAME"   | awk -F'_' '{print $3"_"$4}')"
  RGID="${SAMPLE}_${LANE}"
  RGSM="$SAMPLE"
  RGPU="$LANE"
  RGLB="lib1"
  RGPL="ILLUMINA"

  echo "============ $(date) : $BASENAME ============"

  # ---- fastp adapter/quality trimming ----
  TRIM_R1="${TRIMDIR}/${BASENAME}_R1.trimmed.fastq.gz"
  TRIM_R2="${TRIMDIR}/${BASENAME}_R2.trimmed.fastq.gz"
  TRIM_HTML="${TRIMDIR}/${BASENAME}.fastp.html"
  TRIM_JSON="${TRIMDIR}/${BASENAME}.fastp.json"

  echo "[INFO] fastp trimming $BASENAME"
  fastp \
    -i "$R1" -I "$R2" \
    -o "$TRIM_R1" -O "$TRIM_R2" \
    --detect_adapter_for_pe \
    --cut_right \
    --length_required 50 \
    --thread "$THREADS" \
    --html "$TRIM_HTML" \
    --json "$TRIM_JSON"

  # ---- alignment, sort, QC ----
  BAM_SORTED="${OUTDIR}/${BASENAME}.sorted.bam"
  echo "[INFO] Align + sort $BASENAME"
  bwa-mem2 mem -t "$THREADS" \
      -R "@RG\tID:${RGID}\tSM:${RGSM}\tLB:${RGLB}\tPL:${RGPL}\tPU:${RGPU}" \
      "$REF" "$TRIM_R1" "$TRIM_R2" \
    | samtools sort -@ $((THREADS/2)) -o "$BAM_SORTED" -
  samtools index "$BAM_SORTED"

  samtools flagstat "$BAM_SORTED" > "${LOGDIR}/${BASENAME}.flagstat.predup.txt"
  samtools idxstats "$BAM_SORTED" > "${LOGDIR}/${BASENAME}.idxstats.txt"

  # ---- mark duplicates ----
  BAM_DEDUP="${OUTDIR}/${BASENAME}.dedup.bam"
  METRICS="${OUTDIR}/${BASENAME}.dup_metrics.txt"
  echo "[INFO] MarkDuplicates $BASENAME"
  gatk --java-options "-Xms4g -Xmx96g" MarkDuplicates \
      -I "$BAM_SORTED" \
      -O "$BAM_DEDUP" \
      -M "$METRICS" \
      --CREATE_INDEX true
  samtools flagstat "$BAM_DEDUP" > "${LOGDIR}/${BASENAME}.flagstat.dedup.txt"

  # ---- per-sample gVCF ----
  GVCF="${OUTDIR}/${BASENAME}.g.vcf.gz"
  echo "[INFO] HaplotypeCaller (gVCF) $BASENAME"
  gatk --java-options "-Xms4g -Xmx96g" HaplotypeCaller \
      -R "$REF" \
      -I "$BAM_DEDUP" \
      -O "$GVCF" \
      -ERC GVCF \
      --native-pair-hmm-threads $((THREADS/2)) \
      --sample-ploidy 2

  echo "[OK] $(date) $BASENAME → $GVCF"
done

echo "All done at $(date)"

