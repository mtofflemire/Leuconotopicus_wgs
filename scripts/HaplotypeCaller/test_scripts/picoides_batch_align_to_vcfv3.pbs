#!/bin/bash
#PBS -V
#PBS -N picoides_batch_align_to_vcf
#PBS -l nodes=1:ppn=16,mem=128gb,walltime=48:00:00
#PBS -q batch
#PBS -j oe
#PBS -o batch_align_to_vcf.log
#PBS -M mtofflemire@sdsu.edu

set -euo pipefail
cd "$PBS_O_WORKDIR"

# ---- activate env ----
source ~/miniconda3/etc/profile.d/conda.sh
conda activate genomics
export _JAVA_OPTIONS="-Xms2g -Xmx96g -XX:ParallelGCThreads=4"

# ===== paths =====
REF="/usr/scratch2/userdata2/mtofflemire/references/ncbi_dataset/data/GCF_014839835.1/GCF_014839835.1_bDryPub1.pri_genomic.fna"
FASTQ_DIR="/usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/data/fastq"

# new timestamped run folder (prevents overwriting existing results)
DATESTAMP=$(date +%Y%m%d_%H%M%S)
OUTDIR="/usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/data/alignments/run_${DATESTAMP}"

# total cores requested from PBS header
THREADS_TOTAL=16
# ===================

# -------- parallelization knobs --------
SAMPLES_IN_PARALLEL=2                              # start with 2; increase if I/O is fine
THREADS=$(( THREADS_TOTAL / SAMPLES_IN_PARALLEL )) # per-sample threads
export OMP_NUM_THREADS="$THREADS"

# simple concurrency gate
runlim() { while [ "$(jobs -rp | wc -l)" -ge "$SAMPLES_IN_PARALLEL" ]; do sleep 1; done; }

# outputs on shared scratch; temps on node-local disk
mkdir -p "$OUTDIR" "/usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/out"
TMPDIR_JOB="${PBS_JOBTMP:-/tmp}/${USER}_${PBS_JOBID:-$$}"
mkdir -p "$TMPDIR_JOB"
export TMPDIR="$TMPDIR_JOB"
trap 'rm -rf "$TMPDIR_JOB"' EXIT

# Index reference once (safe to re-run; skips if present)
[ -f "${REF}.bwt" ] || bwa index "$REF"
[ -f "${REF}.fai" ] || samtools faidx "$REF"
DICT="${REF%.*}.dict"; [ -f "$DICT" ] || gatk CreateSequenceDictionary -R "$REF" -O "$DICT"

echo "Run started at $(date)"
echo "Writing outputs to: $OUTDIR"
echo "Parallel samples: $SAMPLES_IN_PARALLEL; Threads per sample: $THREADS"

# ---------- main loop (parallelized across samples) ----------
for R1 in "$FASTQ_DIR"/*_R1_*.fastq.gz; do
  [ -e "$R1" ] || { echo "No R1 files found in $FASTQ_DIR"; exit 1; }
  R2="${R1/_R1_/_R2_}"
  if [[ ! -f "$R2" ]]; then
    echo "Missing mate for $R1 (expected $R2) — skipping"; continue
  fi

  runlim
  (
    set -euo pipefail

    # Derive a base name like: 25002Bns_Palb-XXX_SNN_L007
    base=$(basename "$R1")
    BASENAME="${base%%_R1_*}"

    # Per-sample TMP to avoid collisions
    TMPDIR_SAMPLE="$TMPDIR/${BASENAME}"
    mkdir -p "$TMPDIR_SAMPLE"

    # Read group fields (from filename)
    SAMPLE="$(echo "$BASENAME" | awk -F'_' '{print $2}')"       # e.g., Palb-DMNS47995
    LANE="$(echo "$BASENAME"   | awk -F'_' '{print $3"_"$4}')"  # e.g., S61_L007
    RGID="${SAMPLE}_${LANE}"
    RGPU="$LANE"
    RGSM="$SAMPLE"

    echo ">>> [$(date)] Processing $BASENAME (threads/sample: $THREADS)"

    BAM_SORTED="${OUTDIR}/${BASENAME}.sorted.bam"
    BAM_RG="${OUTDIR}/${BASENAME}.sorted_rg.bam"
    BAM_DEDUP="${OUTDIR}/${BASENAME}.dedup.bam"
    METRICS="${OUTDIR}/${BASENAME}.dup_metrics.txt"
    GVCF="${OUTDIR}/${BASENAME}.g.vcf.gz"

    # Align & sort (use node-local TMPDIR for sort chunks)
    bwa mem -t "$THREADS" "$REF" "$R1" "$R2" \
      | samtools sort -@ $((THREADS/2>0?THREADS/2:1)) -T "$TMPDIR_SAMPLE/${BASENAME}.tmp" -o "$BAM_SORTED" -
    samtools index -@ 2 "$BAM_SORTED"

    # Quick mapping summary
    samtools flagstat -@ 2 "$BAM_SORTED" > "${OUTDIR}/${BASENAME}.flagstat.txt"
    samtools idxstats "$BAM_SORTED" > "${OUTDIR}/${BASENAME}.idxstats.txt"

    # Add read groups
    picard AddOrReplaceReadGroups \
      I="$BAM_SORTED" O="$BAM_RG" \
      RGID="$RGID" RGLB="lib1" RGPL="ILLUMINA" RGPU="$RGPU" RGSM="$RGSM" \
      CREATE_INDEX=true VALIDATION_STRINGENCY=SILENT

    # Mark duplicates
    picard MarkDuplicates \
      I="$BAM_RG" O="$BAM_DEDUP" M="$METRICS" \
      CREATE_INDEX=true VALIDATION_STRINGENCY=SILENT

    # Call variants (gVCF)
    gatk HaplotypeCaller \
      -R "$REF" -I "$BAM_DEDUP" -O "$GVCF" -ERC GVCF \
      --native-pair-hmm-threads "$THREADS"

    echo "✔ [$(date)] $BASENAME -> $GVCF"
  ) &
done

wait
echo "All done at $(date)"

