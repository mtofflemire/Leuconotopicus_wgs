# 12_run_admixture_simple.pbs
#!/bin/bash
#PBS -V
#PBS -N admixture_picoides
#PBS -l nodes=1:ppn=20,mem=128gb,walltime=04:00:00
#PBS -q batch
#PBS -o /usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/out/admixture.log
#PBS -j oe

set -euo pipefail
cd "$PBS_O_WORKDIR"

# activate admixture conda environment
source ~/miniconda3/etc/profile.d/conda.sh
conda activate admixture_env

# input prefix (your PLINK files already created)
OUT2=/usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/out2
PREFIX=$OUT2/picoides

# fix .bim for ADMIXTURE (numeric chrom codes)
BIM=${PREFIX}.bim
awk '{$1=0; print}' OFS='\t' "$BIM" > ${BIM}.tmp && mv ${BIM}.tmp "$BIM"

# run admixture for K = 1..5
for K in {1..5}; do
  admixture --cv=10 -j8 ${PREFIX}.bed $K | tee ${PREFIX}.K${K}.log
done

