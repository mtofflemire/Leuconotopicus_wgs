#!/bin/sh
#PBS -V
#PBS -l nodes=1:ppn=12  # Request 4 cores
#PBS -l walltime=72:00:00
#PBS -N admixture_run
#PBS -j oe  # Combine stdout and stderr
#PBS -o admixture_run.txt  # Output log file
#PBS -M mtofflemire@sdsu.edu  # Email notifications (if configured)
#PBS -q batch  # Cluster queue

# Move to the working directory
cd $PBS_O_WORKDIR || exit

# Define ADMIXTURE binary location
ADMIXTURE_BIN="/usr/scratch2/userdata2/mtofflemire/projects/chamaea/systems/dist/admixture_linux-1.3.0/admixture"

# Verify ADMIXTURE is executable
if [ ! -x "$ADMIXTURE_BIN" ]; then
    echo "Error: ADMIXTURE binary is not executable!"
    exit 1
fi

# Define input file (without extension)
BEDFILE="/home/mtofflemire/41-Chamaea_HWE_no_missing"

# Verify input files exist
if [ ! -f "${BEDFILE}.bed" ]; then
    echo "Error: BED file not found at ${BEDFILE}.bed"
    exit 1
fi

# Define output directory
OUTDIR="/home/mtofflemire/admixture_results"
mkdir -p $OUTDIR  # Ensure output directory exists

# Move to the directory where the BED file is located
cd /home/mtofflemire || exit

# Log system details
echo "Running on host: $(hostname)"
echo "Job submitted on: $(date)"
echo "Using $PBS_NP cores"

# Run ADMIXTURE for K=1 to K=10 with 4 threads
for K in {1..10}; do
    echo "Running ADMIXTURE for K=$K..."

    # Run ADMIXTURE
    $ADMIXTURE_BIN --cv -j12 ${BEDFILE}.bed $K | tee log_${K}.out

    # Move output files to the results directory
    mv ${BEDFILE}.${K}.P ${OUTDIR}/K${K}.P 2>/dev/null
    mv ${BEDFILE}.${K}.Q ${OUTDIR}/K${K}.Q 2>/dev/null
    mv log_${K}.out ${OUTDIR}/log_${K}.out 2>/dev/null
done

echo "ADMIXTURE analysis complete! All results saved in $OUTDIR"
