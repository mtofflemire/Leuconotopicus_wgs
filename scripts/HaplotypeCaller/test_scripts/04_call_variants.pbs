#!/bin/bash
#PBS -V
#PBS -N hc_gvcf
#PBS -l nodes=1:ppn=20,mem=64gb,walltime=500:00:00
#PBS -q batch
#PBS -j oe
#PBS -o /usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/out/hc_gvcf.log

set -euo pipefail
cd "$PBS_O_WORKDIR"
source ~/miniconda3/etc/profile.d/conda.sh; conda activate genomics

# set SAMPLE like: qsub -v SAMPLE=25002Bns_Palb-DMNS47995_S61_L007 hc_gvcf.pbs
: "${SAMPLE:?set with qsub -v SAMPLE=<basename-without-.dedup.bam>}"

REF="/usr/scratch2/userdata2/mtofflemire/references/ncbi_dataset/data/GCF_014839835.1/GCF_014839835.1_bDryPub1.pri_genomic.fna"
BAM_DIR="/usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/data/alignments2"
OUT_DIR="/usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/SNP_calling/bams/gvcfs/${SAMPLE}"
mkdir -p "$OUT_DIR"

gatk --java-options "-Xmx16g" HaplotypeCaller -R "$REF" -I "$BAM_DIR/${SAMPLE}.dedup.bam" -O "$OUT_DIR/${SAMPLE}.g.vcf.gz" -ERC GVCF --native-pair-hmm-threads "${PBS_NUM_PPN:-4}"

gatk IndexFeatureFile -I "$OUT_DIR/${SAMPLE}.g.vcf.gz"
