# 08_sort_index_picoides.pbs
#!/bin/bash
#PBS -V
#PBS -N sort_picoides
#PBS -l nodes=1:ppn=1,mem=8gb,walltime=01:00:00
#PBS -q batch
#PBS -o /usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/out/sort_picoides.log
#PBS -j oe

set -euo pipefail
source ~/miniconda3/etc/profile.d/conda.sh
conda activate genomics

OUT2=/usr/scratch2/userdata2/mtofflemire/projects/picoides_genotyping/out2
REF=/usr/scratch2/userdata2/mtofflemire/references/ncbi_dataset/data/GCF_014839835.1/GCF_014839835.1_bDryPub1.pri_genomic.fna
DICT=${REF%.fna}.dict

cd "$OUT2"

gatk SortVcf -I picoides.raw.merged.vcf.gz \
  -O picoides.raw.merged.sorted.vcf.gz \
  --SEQUENCE_DICTIONARY "$DICT"

gatk IndexFeatureFile -I picoides.raw.merged.sorted.vcf.gz

